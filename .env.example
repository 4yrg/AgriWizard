# ─────────────────────────────────────────────────────────────────────────────
#  AgriWizard — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=agriwizard
DB_PASSWORD=agriwizard_secret         # CHANGE IN PRODUCTION
IAM_DB_NAME=iam_db
HARDWARE_DB_NAME=hardware_db
ANALYTICS_DB_NAME=analytics_db

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production   # CHANGE — min 32 chars
JWT_TTL_HOURS=24

# ── MQTT ──────────────────────────────────────────────────────────────────────
MQTT_BROKER=ssl://your-hivemq-cloud-cluster-host.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=your-hivemq-cloud-username
MQTT_PASSWORD=your-hivemq-cloud-password

# ── Service Ports ─────────────────────────────────────────────────────────────
IAM_PORT=8081
HARDWARE_PORT=8082
ANALYTICS_PORT=8083
WEATHER_PORT=8084

# ── Inter-service URLs (used inside Docker network) ───────────────────────────
ANALYTICS_SERVICE_URL=http://analytics-service:8083
HARDWARE_SERVICE_URL=http://hardware-service:8082
WEATHER_SERVICE_URL=http://weather-service:8084

# ── Weather (OpenWeatherMap) ──────────────────────────────────────────────────
USE_MOCK=true                          # Set to false to use live OWM data
OWM_API_KEY=                           # Your OpenWeatherMap API key
OWM_BASE_URL=https://api.openweathermap.org/data/2.5
LOCATION_LAT=6.9271                    # Colombo, Sri Lanka
LOCATION_LON=79.8612
LOCATION_CITY=Colombo

# ── Gin ───────────────────────────────────────────────────────────────────────
GIN_MODE=debug                         # Set to 'release' in production

# ── Azure Container Registry ──────────────────────────────────────────────────
# (Only needed for CI/CD — set as GitHub Secrets, not here)
# ACR_REGISTRY=agriwizard.azurecr.io
# ACR_USERNAME=
# ACR_PASSWORD=
