# -----------------------------------------------------------------------------
# AgriWizard Environment Variables (example)
# Copy to .env and update values for your environment.
# -----------------------------------------------------------------------------

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=agriwizard
DB_PASSWORD=agriwizard_secret
DB_NAME=agriwizard
DB_SSLMODE=disable

# JWT
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_TTL_HOURS=24
JWT_ISSUER=agriwizard-iam

# HiveMQ / MQTT
MQTT_BROKER=ssl://your-hivemq-cluster.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=your-username
MQTT_PASSWORD=your-password
MQTT_CLIENT_ID=agriwizard-hardware
MQTT_TOPIC_PREFIX=agri/greenhouse
MQTT_TLS_ENABLED=true

# Service Ports
IAM_PORT=8081
HARDWARE_PORT=8082
ANALYTICS_PORT=8083
WEATHER_PORT=8084
NOTIFICATION_PORT=8085

# Inter-service URLs (local docker network defaults)
ANALYTICS_SERVICE_URL=http://analytics-service:8083
HARDWARE_SERVICE_URL=http://hardware-service:8082
WEATHER_SERVICE_URL=http://weather-service:8084

# Kong API Gateway
KONG_ADMIN_URL=http://kong:8001
KONG_PROXY_URL=http://localhost:8000
KONG_JWT_SHARED_SECRET=super-secret-jwt-key-change-in-production
CORS_ALLOW_ORIGIN=*

# Weather (OpenWeatherMap)
USE_MOCK=true
OWM_API_KEY=
OWM_BASE_URL=https://api.openweathermap.org/data/2.5
LOCATION_LAT=6.9271
LOCATION_LON=79.8612
LOCATION_CITY=Colombo

# Notification service
NATS_URL=nats://nats:4222
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@agriwizard.local
SMTP_USERNAME=
SMTP_PASSWORD=

# Gin mode
GIN_MODE=debug

# Azure Container Registry (for CI/CD)
# ACR_REGISTRY=agriwizard.azurecr.io
# ACR_USERNAME=
# ACR_PASSWORD=
