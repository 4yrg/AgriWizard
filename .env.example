# -----------------------------------------------------------------------------
# AgriWizard Environment Variables
# -----------------------------------------------------------------------------
# Copy to .env and update values for your environment.

# =============================================================================
# LOCAL DEVELOPMENT
# =============================================================================
# These are the defaults for local development with Docker Compose

# ── Database (PostgreSQL) ───────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USER=agriwizard
DB_PASSWORD=agriwizard_secret
DB_NAME=agriwizard
DB_SSLMODE=disable

# ── JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production
JWT_TTL_HOURS=24
JWT_ISSUER=agriwizard-iam

# ── MQTT / IoT (HiveMQ Cloud) ────────────────────────────────────────────────
# For local dev, you can use HiveMQ Cloud or skip (USE_MOCK=true)
MQTT_BROKER=ssl://your-hivemq-cluster.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=your-hivemq-username
MQTT_PASSWORD=your-hivemq-password
MQTT_CLIENT_ID=agriwizard-hardware
MQTT_TOPIC_PREFIX=agriwizard
MQTT_TLS_ENABLED=true

# ── Service Ports (external) ──────────────────────────────────────────────
# External ports map to internal service ports
IAM_PORT=8081
HARDWARE_PORT=8082
ANALYTICS_PORT=8083
WEATHER_PORT=8085
NOTIFICATION_PORT=8096
KONG_PROXY_PORT=8000
SWAGGER_UI_PORT=8090

# ── Messaging (RabbitMQ) ─────────────────────────────────────────────
RABBITMQ_PORT=8092
RABBITMQ_MGMT_PORT=8093

# ── Messaging (NATS) ────────────────────────────────────────────
NATS_PORT=8094
NATS_MONITOR_PORT=8095

# ── Inter-service URLs (Docker network) ────────────────────────────
# Services communicate via these internal URLs
IAM_SERVICE_URL=http://iam-service:8086
HARDWARE_SERVICE_URL=http://hardware-service:8087
ANALYTICS_SERVICE_URL=http://analytics-service:8088
WEATHER_SERVICE_URL=http://weather-service:8089
NOTIFICATION_SERVICE_URL=http://notification-service:8091

# ── Weather (OpenWeatherMap) ─────────────────────────────────────────────
# USE_MOCK=true for local dev without OWM API key
USE_MOCK=true
OWM_API_KEY=
OWM_BASE_URL=https://api.openweathermap.org/data/2.5
LOCATION_LAT=6.9271
LOCATION_LON=79.8612
LOCATION_CITY=Colombo

# ── Notification (Mailhog for dev) ────────────────────────────
NATS_URL=nats://nats:4222
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_FROM=noreply@agriwizard.local
SMTP_USERNAME=
SMTP_PASSWORD=

# ── Gin Mode ───────────────────────────────────────────────────
GIN_MODE=debug

# ── Kong API Gateway ───────────────────────────────────────────
KONG_ADMIN_URL=http://kong:8001
KONG_PROXY_URL=http://localhost:8000
KONG_JWT_SHARED_SECRET=super-secret-jwt-key-change-in-production
KONG_JWT_ISSUER=agriwizard-iam
CORS_ALLOW_ORIGIN=*

# =============================================================================
# AZURE PRODUCTION
# =============================================================================
# These variables are injected automatically by Azure Bicep + Container Apps.
# They are listed here for reference only — do NOT commit actual secrets.
#
# All secrets are stored in Azure Key Vault (agriwizard-kv) and injected
# into Container Apps as environment variables at deploy time.

# ── Azure Database for PostgreSQL Flexible Server ─────────────
# DB_HOST=agriwizard-postgres.postgres.database.azure.com
# DB_PORT=5432
# DB_USER=agriwizard
# DB_PASSWORD=<KeyVault:db-password>
# DB_NAME=agriwizard
# DB_SSLMODE=require

# ── Azure Service Bus (replaces RabbitMQ + NATS in production) ─
# SERVICE_BUS_CONNECTION=<KeyVault:servicebus-connection>
# SERVICE_BUS_TOPIC=telemetry              (hardware → analytics)
# SERVICE_BUS_SUBSCRIPTION=analytics-service
# RABBITMQ_HOST=                           (empty — disables RabbitMQ)
# NATS_URL=                                (empty — disables NATS)

# ── HiveMQ Cloud MQTT (same for dev and prod) ────────────────
# MQTT_BROKER=ssl://your-hivemq-cluster.s1.eu.hivemq.cloud:8883
# MQTT_USERNAME=<KeyVault:mqtt-username>
# MQTT_PASSWORD=<KeyVault:mqtt-password>

# ── Azure Key Vault ───────────────────────────────────────
# KEY_VAULT_NAME=agriwizard-kv

# ── Azure Container Registry ────────────────────────────────
# ACR_NAME=agriwizardacr
# ACR_REGISTRY=agriwizardacr.azurecr.io

# ── Azure Container Apps Environment ──────────────────────────
# ACA_ENV_NAME=agriwizard-aca-env
# ACA_RG=agriwizard-prod-rg

# ── SMTP (production email) ──────────────────────────────
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_FROM=noreply@agriwizard.com
# SMTP_USERNAME=apikey
# SMTP_PASSWORD=<your-sendgrid-api-key>

# ── Production Settings ──────────────────────────────────
# GIN_MODE=release
# USE_MOCK=false