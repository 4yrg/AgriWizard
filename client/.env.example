# -----------------------------------------------------------------------------
# AgriWizard Frontend (Next.js) Environment Variables (example)
# Copy to client/.env.local (or client/.env) and update as needed.
# -----------------------------------------------------------------------------

# Backend API base URL exposed to browser
NEXT_PUBLIC_API_URL=https://agriwizard-prod-gateway.yellowocean-38e04fed.centralindia.azurecontainerapps.io

# SWR polling intervals in milliseconds (0 = disabled)
NEXT_PUBLIC_REFRESH_EQUIPMENT_MS=0
NEXT_PUBLIC_REFRESH_SENSORS_MS=0
NEXT_PUBLIC_REFRESH_PARAMETERS_MS=0
NEXT_PUBLIC_REFRESH_DECISIONS_MS=0
NEXT_PUBLIC_REFRESH_DAILY_SUMMARIES_MS=0

# Weather polling intervals (defaults)
NEXT_PUBLIC_REFRESH_WEATHER_CURRENT_MS=60000
NEXT_PUBLIC_REFRESH_WEATHER_FORECAST_MS=300000
NEXT_PUBLIC_REFRESH_WEATHER_ALERTS_MS=60000
NEXT_PUBLIC_REFRESH_IRRIGATION_RECOMMENDATION_MS=300000
