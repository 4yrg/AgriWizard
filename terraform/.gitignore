# Terraform state files
*.tfstate
*.tfstate.*
*.tfplan
*.backup

# Crash logs
crash.log
crash.*.log

# Directory for local .terraform
.terraform/
.terraform.lock.hcl

# Override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Include tfplan files
*.tfplan

# Sensitive files
*.pem
*.key
*.pfx
*.crt

# Environment-specific secrets (keep templates, not actual values)
environments/*.secret.tfvars
!environments/*.tfvars.example

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Log files
*.log

# Temporary files
tmp/
temp/
*.tmp
