  Serial.begin(115200);
  randomSeed(analogRead(0)); // Initialize random generator
  
  pinMode(FAN_PIN, OUTPUT);
  pinMode(PUMP_PIN, OUTPUT);
  digitalWrite(FAN_PIN, LOW);
  digitalWrite(PUMP_PIN, LOW);

  setupTopics();
  connectWiFi();
  espClient.setInsecure(); 
  connectMQTT();
}

void loop() {
  if (WiFi.status() != WL_CONNECTED) connectWiFi();
  if (!mqttClient.connected()) connectMQTT();

  mqttClient.loop();

  unsigned long now = millis();
  if (now - lastTelemetryMs >= TELEMETRY_INTERVAL_MS) {
    lastTelemetryMs = now;
    
    String allParams[] = {PARAM_TEMP, PARAM_HUMIDITY, PARAM_SOIL};
    publishTelemetry(allParams, 3, SENSOR_ID);

    String tempHum[] = {PARAM_TEMP, PARAM_HUMIDITY};
    publishTelemetry(tempHum, 2, TMP_SENSOR_ID);

  }
}