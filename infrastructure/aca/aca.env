# Copy to infrastructure/aca/aca.env and update values before running scripts.

# Azure scope
SUBSCRIPTION_ID=71dc1447-483b-4aa3-b549-021a60ec7241
RESOURCE_GROUP=agriwizard-rg
LOCATION=centralindia

# Core platform resources
ACA_ENV_NAME=agriwizard-aca-env
ACR_NAME=agriwizardacr
LOG_ANALYTICS_NAME=agriwizard-law
APP_INSIGHTS_NAME=agriwizard-appinsights

# Image tagging
IMAGE_TAG=latest

# Shared app configuration
JWT_SECRET=agriwizard-jwt-secret-key-min-32-chars
JWT_ISSUER=agriwizard-iam
CORS_ALLOW_ORIGIN=*

# Data plane dependencies (set after PostgreSQL is created)
POSTGRES_HOST=agriwizard-db.postgres.database.azure.com
POSTGRES_PORT=5432
POSTGRES_DB=agriwizard
POSTGRES_USER=agriwizard
POSTGRES_PASSWORD=AgriWizard@123

# RabbitMQ (inter-service messaging)
RABBITMQ_HOST=agriwizard-rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
RABBITMQ_QUEUE=telemetry

# Hardware / MQTT (IoT)
MQTT_BROKER=ssl://0844c36e03374e7682f81036bb673d45.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=Hasintha
MQTT_PASSWORD='Agriwizard@999'

# Notification transport
NATS_URL=nats://nats:4222
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_FROM=noreply@agriwizard.com
SMTP_USERNAME=
SMTP_PASSWORD=

# Weather defaults
USE_MOCK=true
OWM_API_KEY=
OWM_BASE_URL=https://api.openweathermap.org/data/2.5
LOCATION_LAT=6.9271
LOCATION_LON=79.8612
LOCATION_CITY=Colombo