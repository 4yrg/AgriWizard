# =============================================================================
# Terraform Backend Configuration
# =============================================================================
# Copy this file to override default local state
#
# IMPORTANT: Replace 'tfstateXXXXX' with your actual storage account name
# =============================================================================

terraform {
  backend "azurerm" {
    resource_group_name  = "agriwizard-tf-rg"
    storage_account_name = "tfstateXXXXX"  # REPLACE with your storage account name
    container_name     = "tfstate"
    key                = "agriwizard/dev/terraform.tfstate"
    use_azuread_auth   = true
  }
}