              "apiVersion": "2024-01-01",
              "name": "[format('{0}/{1}/{2}', parameters('serviceBusName'), 'notifications', 'notification-service')]",
              "properties": {
                "lockDuration": "PT30S",
                "maxDeliveryCount": 10,
