# ─────────────────────────────────────────────────────────────────────────────
#  AgriWizard — Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit the real .env file to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=gradeloop-gradeloop-project.k.aivencloud.com
DB_PORT=21005
DB_USER=avnadmin
DB_PASSWORD=<aiven-password>
DB_NAME=defaultdb
DB_SSLMODE=require

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=super-secret-jwt-key-change-in-production   # CHANGE — min 32 chars
JWT_TTL_HOURS=24

# ── MQTT ──────────────────────────────────────────────────────────────────────
MQTT_BROKER=ssl://0844c36e03374e7682f81036bb673d45.s1.eu.hivemq.cloud:8883
MQTT_USERNAME=Hasintha
MQTT_PASSWORD=Agriwizard@999

# ── Service Ports ─────────────────────────────────────────────────────────────
# Default standard ports for development
IAM_PORT=8081
HARDWARE_PORT=8082
ANALYTICS_PORT=8083
WEATHER_PORT=8085
NOTIFICATION_PORT=8096
KONG_PROXY_PORT=8000

# ── Inter-service URLs (used inside Docker network) ───────────────────────────
ANALYTICS_SERVICE_URL=http://analytics-service:8088
HARDWARE_SERVICE_URL=http://hardware-service:8087
WEATHER_SERVICE_URL=http://weather-service:8089

# ── Weather (OpenWeatherMap) ──────────────────────────────────────────────────
USE_MOCK=true                          # Set to false to use live OWM data
OWM_API_KEY=                           # Your OpenWeatherMap API key
OWM_BASE_URL=https://api.openweathermap.org/data/2.5
LOCATION_LAT=6.9271                    # Colombo, Sri Lanka
LOCATION_LON=79.8612
LOCATION_CITY=Colombo

# ── Gin ───────────────────────────────────────────────────────────────────────
GIN_MODE=debug                         # Set to 'release' in production

# ── Azure Container Registry ──────────────────────────────────────────────────
# (Only needed for CI/CD — set as GitHub Secrets, not here)
# ACR_REGISTRY=agriwizard.azurecr.io
# ACR_USERNAME=
# ACR_PASSWORD=