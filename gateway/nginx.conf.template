        location = /api/v1/notifications {
            return 301 /api/v1/notifications/;
        }

        location ^~ /api/v1/notifications/ {
            rewrite ^/api/v1/notifications/health/?$ /health break;
            proxy_pass https://${NOTIFICATION_SERVICE_HOST};
            proxy_ssl_verify off;
            proxy_ssl_server_name on;
            proxy_set_header Host $proxy_host;

            # CORS Headers
            add_header 'Access-Control-Allow-Origin' 'https://agri-wizard.vercel.app' always;
            add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, DELETE, OPTIONS' always;
            add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization' always;
            add_header 'Access-Control-Expose-Headers' 'Content-Length,Content-Range' always;

            if ($request_method = 'OPTIONS') {
                add_header 'Access-Control-Allow-Origin' 'https://agri-wizard.vercel.app' always;
                add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, DELETE, OPTIONS' always;
                add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization' always;
                add_header 'Access-Control-Max-Age' 1728000;
                add_header 'Content-Type' 'text/plain; charset=utf-8';
                add_header 'Content-Length' 0;
                return 204;
            }
            proxy_set_header X-Forwarded-Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            ${NOTIFICATION_SSL_CONFIG}
        }

        location = /api/v1/templates {
            return 301 /api/v1/templates/;
        }

        location ^~ /api/v1/templates/ {
            proxy_pass https://${NOTIFICATION_SERVICE_HOST};
            proxy_ssl_verify off;
            proxy_ssl_server_name on;
            proxy_set_header Host $proxy_host;

            # CORS Headers
            add_header 'Access-Control-Allow-Origin' 'https://agri-wizard.vercel.app' always;
            add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, DELETE, OPTIONS' always;
            add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization' always;
            add_header 'Access-Control-Expose-Headers' 'Content-Length,Content-Range' always;

            if ($request_method = 'OPTIONS') {
                add_header 'Access-Control-Allow-Origin' 'https://agri-wizard.vercel.app' always;
                add_header 'Access-Control-Allow-Methods' 'GET, POST, PUT, DELETE, OPTIONS' always;
                add_header 'Access-Control-Allow-Headers' 'DNT,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type,Range,Authorization' always;
                add_header 'Access-Control-Max-Age' 1728000;
                add_header 'Content-Type' 'text/plain; charset=utf-8';
                add_header 'Content-Length' 0;
                return 204;
            }
            proxy_set_header X-Forwarded-Host $host;
            proxy_set_header X-Real-IP $remote_addr;
            proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
            proxy_set_header X-Forwarded-Proto $scheme;
            ${NOTIFICATION_SSL_CONFIG}
            proxy_redirect off;
        }

        location = /health {
            access_log off;
            add_header Content-Type text/plain;
            add_header 'Access-Control-Allow-Origin' 'https://agri-wizard.vercel.app' always;
            return 200 "healthy\n";
        }
    }
}
