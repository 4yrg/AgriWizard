{
  "$schema": "https://www.krakend.io/schema/v2.7/krakend.json",
  "version": 3,
  "name": "AgriWizard API Gateway",
  "port": 8080,
  "timeout": "10s",
  "cache_ttl": "300s",
  "output_encoding": "json",
  "extra_config": {
    "telemetry/logging": {
      "level": "INFO",
      "prefix": "[KRAKEND]",
      "syslog": false,
      "stdout": true
    },
    "security/cors": {
      "allow_origins": ["*"],
      "allow_methods": ["GET", "POST", "PUT", "DELETE", "OPTIONS"],
      "allow_headers": ["Origin", "Authorization", "Content-Type", "X-Request-ID"],
      "expose_headers": ["Content-Length"],
      "max_age": "12h"
    }
  },
  "endpoints": [

    {
      "endpoint": "/api/v1/iam/register",
      "method": "POST",
      "output_encoding": "json",
      "backend": [{
        "url_pattern": "/api/v1/iam/register",
        "host": ["http://iam-service:8081"],
        "encoding": "json"
      }]
    },
    {
      "endpoint": "/api/v1/iam/login",
      "method": "POST",
      "output_encoding": "json",
      "backend": [{
        "url_pattern": "/api/v1/iam/login",
        "host": ["http://iam-service:8081"],
        "encoding": "json"
      }]
    },
    {
      "endpoint": "/api/v1/iam/introspect",
      "method": "GET",
      "output_encoding": "json",
      "backend": [{
        "url_pattern": "/api/v1/iam/introspect",
        "host": ["http://iam-service:8081"],
        "encoding": "json"
      }]
    },

    {
      "endpoint": "/api/v1/iam/profile",
      "method": "GET",
      "output_encoding": "json",
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "jwk_url": "http://iam-service:8081/api/v1/iam/introspect",
          "disable_jwk_security": true,
          "secret_url": "base64url:__JWT_SECRET_BASE64__",
          "propagate_claims": [["user_id", "X-User-ID"], ["role", "X-User-Role"]]
        }
      },
      "backend": [{
        "url_pattern": "/api/v1/iam/profile",
        "host": ["http://iam-service:8081"],
        "encoding": "json"
      }]
    },
    {
      "endpoint": "/api/v1/iam/profile",
      "method": "PUT",
      "output_encoding": "json",
      "extra_config": {
        "auth/validator": {
          "alg": "HS256",
          "disable_jwk_security": true,
          "secret_url": "base64url:__JWT_SECRET_BASE64__"
        }
      },
      "backend": [{
        "url_pattern": "/api/v1/iam/profile",
        "host": ["http://iam-service:8081"],
        "encoding": "json"
      }]
    },

