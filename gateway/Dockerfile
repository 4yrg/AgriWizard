FROM nginx:alpine

RUN apk add --no-cache gettext

COPY nginx.conf.template /etc/nginx/nginx.conf.template

EXPOSE 8080

CMD ["/bin/sh", "-c", "envsubst '\\$IAM_SERVICE_HOST \\$IAM_SERVICE_PROTOCOL \\$IAM_SSL_CONFIG \\$HARDWARE_SERVICE_HOST \\$HARDWARE_SERVICE_PROTOCOL \\$HARDWARE_SSL_CONFIG \\$ANALYTICS_SERVICE_HOST \\$ANALYTICS_SERVICE_PROTOCOL \\$ANALYTICS_SSL_CONFIG \\$WEATHER_SERVICE_HOST \\$WEATHER_SERVICE_PROTOCOL \\$WEATHER_SSL_CONFIG \\$NOTIFICATION_SERVICE_HOST \\$NOTIFICATION_SERVICE_PROTOCOL \\$NOTIFICATION_SSL_CONFIG' < /etc/nginx/nginx.conf.template > /etc/nginx/nginx.conf && exec nginx -g 'daemon off;'"]