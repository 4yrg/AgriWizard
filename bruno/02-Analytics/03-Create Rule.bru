meta {
  name: Create Rule
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/analytics/rules
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "threshold_id": "{{thresholdId}}",
    "equipment_id": "{{equipmentId}}",
    "low_action": "ON",
    "high_action": "OFF"
  }
}
