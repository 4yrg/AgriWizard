meta {
  name: Create Parameter
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/v1/hardware/parameters
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "id": "{{parameterId}}",
    "unit": "%",
    "description": "Volumetric soil moisture percentage"
  }
}
