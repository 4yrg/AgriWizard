meta {
  name: Create Equipment
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/hardware/equipments
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Main Water Pump",
    "supported_operations": ["ON", "OFF", "REVERSE"],
    "api_url": "http://192.168.1.10/control"
  }
}
