meta {
  name: Ingest Telemetry
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/api/v1/hardware/telemetry
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "sensor_id": "{{sensorId}}",
    "readings": [
      {
        "parameter_id": "{{parameterId}}",
        "value": 42.5
      }
    ],
    "timestamp": "2026-03-21T10:00:00Z"
  }
}
