meta {
  name: Dispatch Control
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/hardware/control/{{equipmentId}}
  body: json
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "operation": "ON",
    "payload": {
      "source": "bruno"
    }
  }
}
