meta {
  name: Register
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/iam/register
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "email": "{{userEmail}}",
    "password": "{{userPassword}}",
    "full_name": "{{fullName}}",
    "phone": "{{phone}}",
    "role": "{{role}}"
  }
}
